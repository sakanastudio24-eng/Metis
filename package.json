{
  "name": "metis",
  "version": "0.0.0.59",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test:logic": "rm -rf .tmp-tests && tsc -p tsconfig.tests.json && node -e \"require('node:fs').writeFileSync('.tmp-tests/package.json', JSON.stringify({ type: 'commonjs' }))\" && node --test .tmp-tests/tests/phase-4-logic.test.js",
    "clean": "rm -rf dist",
    "visual:test": "node scripts/serve-visual-test.mjs",
    "visual:test:extension": "pnpm build"
  },
  "dependencies": {
    "lucide-react": "^0.487.0",
    "motion": "^12.23.24",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.321",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^7.0.6",
    "vite-plugin-static-copy": "^3.1.2"
  }
}
